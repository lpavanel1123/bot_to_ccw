# Token permanente do bot Vale-LeadTime (developer.webex.com > My Apps)
WEBEX_BOT_TOKEN=seu_bot_token_aqui

# Token pessoal do usuário (expira em 12h — renovar com renew_token.py)
WEBEX_USER_TOKEN=seu_personal_token_aqui

# Segundos entre cada ciclo de polling
POLLING_INTERVAL=5

# Timeout geral em segundos para aguardar resposta do ccwbot
RESPONSE_TIMEOUT=120

# Portal de Cotações — mesma chave do PORTAL_API_KEY no .env do claudeteste
PORTAL_URL=http://localhost:8080
PORTAL_API_KEY=mesma-chave-configurada-no-portal
